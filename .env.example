# ============================================================
# UzASBO 2.0 AI Assistant — Muhit o'zgaruvchilari namunasi
# Bu faylni .env ga nusxalang va qiymatlarni o'zgartiring
# ============================================================

# --- Ollama sozlamalari ---
# Ollama server manzili (mahalliy yoki masofaviy)
OLLAMA_BASE_URL=http://localhost:11434
# Asosiy LLM model nomi (javob generatsiya qilish uchun)
OLLAMA_MODEL=llama3.1:8b
# Embedding model nomi (matnni vektor ga aylantirish uchun)
OLLAMA_EMBED_MODEL=nomic-embed-text

# --- ChromaDB sozlamalari ---
# ChromaDB server manzili
CHROMA_HOST=localhost
# ChromaDB server porti
CHROMA_PORT=8000
# Kolleksiya nomi (vektor ma'lumotlar bazasidagi jadval)
CHROMA_COLLECTION=uzasbo2_knowledge

# --- Redis sozlamalari ---
# Redis server manzili
REDIS_HOST=localhost
# Redis server porti
REDIS_PORT=6379
# Redis parol (agar o'rnatilgan bo'lsa)
REDIS_PASSWORD=
# Redis ma'lumotlar bazasi raqami (0-15)
REDIS_DB=0

# --- FastAPI sozlamalari ---
# Server porti
APP_PORT=8100
# Debug rejim (True/False)
APP_DEBUG=True
# CORS — ruxsat berilgan domenlar (vergul bilan ajratilgan)
CORS_ORIGINS=http://localhost:3000,http://localhost:8080

# --- RAG sozlamalari ---
# Similarity search da nechta chunk qaytarilsin
RAG_TOP_K=5
# LLM temperature (0.0 = aniq, 1.0 = ijodiy)
# Past qiymat = aniqroq javoblar (AI assistant uchun 0.1-0.3 tavsiya)
RAG_TEMPERATURE=0.2
# Chunk hajmi (har bir bo'lakdagi belgilar soni)
RAG_CHUNK_SIZE=800
# Chunklar orasidagi overlap (takrorlanish) — kontekst uzilmasligi uchun
RAG_CHUNK_OVERLAP=200

# --- Chat sozlamalari ---
# Chat tarix saqlash muddati (soniyalarda, 86400 = 1 kun)
CHAT_HISTORY_TTL=86400
# Bitta sessiyada maksimal xabarlar soni
CHAT_MAX_MESSAGES=50
